{
  "name": "deployoor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "viem-first contract deployment: deploy once, use contracts as typed objects.",
  "license": "MIT",
  "author": "Valerio Leo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "deployoor": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin-sdk.d.mts",
        "default": "./dist/plugin-sdk.mjs"
      },
      "require": {
        "types": "./dist/plugin-sdk.d.cts",
        "default": "./dist/plugin-sdk.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "effect": "catalog:",
    "jiti": "^2.7.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "viem": ">=2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tevm": "1.0.0-next.149",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valerioleo/deployoor.git",
    "directory": "packages/deployoor"
  },
  "homepage": "https://github.com/valerioleo/deployoor/tree/main/packages/deployoor#readme",
  "bugs": {
    "url": "https://github.com/valerioleo/deployoor/issues"
  }
}
