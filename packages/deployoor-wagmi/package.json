{
  "name": "@deployoor/wagmi",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Source deployoor deployments into @wagmi/cli — typed contract objects for your app.",
  "license": "MIT",
  "author": "Valerio Leo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "abitype": "^1.2.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@wagmi/cli": ">=2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@wagmi/cli": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valerioleo/deployoor.git",
    "directory": "packages/deployoor-wagmi"
  },
  "homepage": "https://github.com/valerioleo/deployoor/tree/main/packages/deployoor-wagmi#readme",
  "bugs": {
    "url": "https://github.com/valerioleo/deployoor/issues"
  }
}
